{
    "version": "1.0",
    "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "python-dev-guidelines": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Python 开发规范：ruff/mypy 代码质量、项目结构、异常设计、TDD 工作流",
            "promptTriggers": {
                "keywords": [
                    "python",
                    "pytest",
                    "ruff",
                    "mypy",
                    "pydantic",
                    "fastapi",
                    "gradio",
                    "uvicorn",
                    "django",
                    "flask",
                    "uv",
                    "uv add",
                    "uv run",
                    "asyncio",
                    "type hint",
                    "type annotation",
                    "pyproject.toml",
                    "pip install",
                    "venv",
                    "dataclass"
                ],
                "intentPatterns": [
                    "(create|add|implement|write|build).*?(function|class|module|service|api|endpoint|route|interface)",
                    "(fix|handle|design).*?(error|exception|type|typing)",
                    "(how to|best practice|pattern).*?(python|pytest|typing|ruff|mypy|fastapi|gradio)",
                    "(structure|organize|setup).*?(project|package|module)",
                    "(run|execute|write).*?test"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/*.py",
                    "**/pyproject.toml",
                    "**/uv.lock",
                    "**/setup.cfg",
                    "**/.mypy.ini",
                    "**/.ruff.toml"
                ],
                "pathExclusions": [
                    "**/__pycache__/**",
                    "**/.venv/**",
                    "**/venv/**",
                    "**/node_modules/**"
                ]
            }
        },
        "git-workflow": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Git 工作流与提交规范：Conventional Commits、分支命名、PR 流程",
            "promptTriggers": {
                "keywords": [
                    "commit",
                    "git commit",
                    "commit message",
                    "conventional commits",
                    "git push",
                    "pull request",
                    "PR",
                    "branch",
                    "git flow",
                    "提交",
                    "分支",
                    "feat:",
                    "fix:",
                    "chore:"
                ],
                "intentPatterns": [
                    "(write|generate|create|improve).*?(commit|message)",
                    "(commit|push|merge|branch).*?(code|change|feature)",
                    "(create|open|review).*?(PR|pull request)",
                    "how to.*?(commit|branch|PR)"
                ]
            }
        },
        "tdd-workflow": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "TDD 工作流：先写测试→再实现→质量链验证，以及 AI 交叉 review 流程",
            "promptTriggers": {
                "keywords": [
                    "tdd",
                    "test driven",
                    "先写测试",
                    "write test first",
                    "test first",
                    "cross review",
                    "交叉review",
                    "交叉评审",
                    "code review",
                    "verify",
                    "quality check",
                    "质量检查"
                ],
                "intentPatterns": [
                    "(先|first).*?测试",
                    "(write|create|generate).*?test.*?(first|before)",
                    "(cross|ai).*?review",
                    "review.*?(code|changes|diff)",
                    "(quality|validate|verify).*?(code|changes)"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "customization": {
            "pathPatterns": "Adjust to match your project structure",
            "keywords": "Add domain-specific terms relevant to your project",
            "intentPatterns": "Use regex for flexible user intent matching"
        },
        "original_ts_skills": "The original TypeScript skills (backend-dev-guidelines, frontend-dev-guidelines, route-tester, error-tracking) have been removed in favor of Python skills. See git history or the original repo to restore them."
    }
}
